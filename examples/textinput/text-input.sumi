<script>
value := $prop("")
placeholder := $prop("")
cursor := $state(0)
viewOffset := $state(0)
selfW := $self(width)
selfX := $self(x)
selfY := $self(y)
contentW := $derived(selfW - 4)
scrollAnimating := $state(false)
scrollDragging := $state(false)
scrollHeld := $state(false)
scrollAnimStart := $state(int64(0))
scrollAnimFrom := $state(0)
scrollAnimTo := $state(0)

func adjustView() {
    if contentW <= 0 {
        return
    }
    if cursor < viewOffset {
        viewOffset = cursor
    }
    if cursor > viewOffset + contentW {
        viewOffset = cursor - contentW
    }
    if viewOffset < 0 {
        viewOffset = 0
    }
}

func displayText() string {
    text := value
    if len(text) == 0 && len(placeholder) > 0 {
        text = placeholder
    }
    return text
}

func viewStart() int {
    vo := viewOffset
    if len(value) == 0 {
        vo = 0
    }
    if vo < 0 {
        vo = 0
    }
    text := displayText()
    if vo > len(text) {
        vo = len(text)
    }
    return vo
}

func viewEnd() int {
    vo := viewStart()
    end := vo + contentW
    text := displayText()
    if end > len(text) {
        end = len(text)
    }
    return end
}

func leftIndicator() string {
    if contentW <= 0 {
        return ""
    }
    if viewStart() > 0 {
        return "<"
    }
    return " "
}

func visibleContent() string {
    if contentW <= 0 {
        return ""
    }
    text := displayText()
    visible := text[viewStart():viewEnd()]
    pad := ""
    for i := len(visible); i < contentW; i++ {
        pad = pad + " "
    }
    return visible + pad
}

func rightIndicator() string {
    if contentW <= 0 {
        return ""
    }
    if viewEnd() < len(displayText()) {
        return ">"
    }
    return " "
}

func scrollbarVisible() bool {
    return len(value) > contentW && contentW > 0
}

func scrollLeftArrow() string {
    if !scrollbarVisible() {
        return ""
    }
    return "<"
}

func scrollTrackW() int {
    totalW := contentW + 4
    return totalW - 2 - 4
}

func scrollTrack() string {
    if !scrollbarVisible() {
        return ""
    }
    trackW := scrollTrackW()
    if trackW < 1 {
        return ""
    }
    thumbSize := trackW * contentW / len(value)
    if thumbSize < 1 {
        thumbSize = 1
    }
    maxOff := len(value) - contentW
    thumbPos := 0
    if maxOff > 0 {
        thumbPos = (trackW - thumbSize) * viewOffset / maxOff
    }
    if thumbPos < 0 {
        thumbPos = 0
    }
    if thumbPos + thumbSize > trackW {
        thumbPos = trackW - thumbSize
    }
    result := ""
    for i := 0; i < trackW; i++ {
        if i >= thumbPos && i < thumbPos + thumbSize {
            result = result + "#"
        } else {
            result = result + "-"
        }
    }
    return result
}

func scrollSpacer() string {
    if !scrollbarVisible() {
        return ""
    }
    return "  "
}

func scrollRightArrow() string {
    if !scrollbarVisible() {
        return ""
    }
    return ">"
}

func wordLeft() int {
    pos := cursor
    for pos > 0 && value[pos-1] == ' ' {
        pos = pos - 1
    }
    for pos > 0 && value[pos-1] != ' ' {
        pos = pos - 1
    }
    return pos
}

func wordRight() int {
    pos := cursor
    for pos < len(value) && value[pos] != ' ' {
        pos = pos + 1
    }
    for pos < len(value) && value[pos] == ' ' {
        pos = pos + 1
    }
    return pos
}

func clampCursorToView() {
    if cursor < viewOffset {
        cursor = viewOffset
    }
    if cursor > viewOffset + contentW {
        cursor = viewOffset + contentW
    }
    if cursor > len(value) {
        cursor = len(value)
    }
    if cursor < 0 {
        cursor = 0
    }
}

func maxOffset() int {
    return len(value) - contentW
}

func scrollbarY() int {
    return selfY + 1
}

func scrollTrackStart() int {
    return selfX + 1 + 2
}

func viewOffsetForTrackX(trackX int) int {
    trackW := scrollTrackW()
    if trackW <= 0 {
        return viewOffset
    }
    maxOff := maxOffset()
    if maxOff <= 0 {
        return 0
    }
    target := trackX * maxOff / trackW
    if target < 0 {
        target = 0
    }
    if target > maxOff {
        target = maxOff
    }
    return target
}

func cancelAnimation() {
    scrollAnimating = false
    scrollDragging = false
    scrollHeld = false
}

func animateStep() {
    now := time.Now().UnixMilli()
    elapsed := now - scrollAnimStart
    duration := int64(200)
    if elapsed >= duration {
        viewOffset = scrollAnimTo
        scrollAnimating = false
        if scrollHeld {
            scrollDragging = true
        }
        clampCursorToView()
        return
    }
    t := float64(elapsed) / float64(duration)
    inv := 1.0 - t
    eased := 1.0 - inv*inv*inv
    viewOffset = scrollAnimFrom + int(eased*float64(scrollAnimTo-scrollAnimFrom))
    clampCursorToView()
    app.RequestFrame()
}

func startScrollAnimation(target int) {
    scrollAnimating = true
    scrollAnimStart = time.Now().UnixMilli()
    scrollAnimFrom = viewOffset
    scrollAnimTo = target
    app.RequestFrame()
}

func handleEvent(evt input.Event) {
    if evt.Kind == input.EventFrame {
        if scrollAnimating {
            animateStep()
        }
        stopPropagation()
        return
    }
    if evt.Kind == input.EventMouse && evt.Mouse.Action == input.MouseRelease {
        if scrollHeld || scrollDragging {
            scrollHeld = false
            scrollDragging = false
            stopPropagation()
            return
        }
    }
    if evt.Kind == input.EventMouse && evt.Mouse.Action == input.MouseMotion && scrollDragging {
        trackX := evt.Mouse.X - scrollTrackStart()
        viewOffset = viewOffsetForTrackX(trackX)
        clampCursorToView()
        stopPropagation()
        return
    }
    if evt.Kind == input.EventMouse && evt.Mouse.Action == input.MousePress && evt.Mouse.Button == input.ButtonLeft && evt.Mouse.Y == scrollbarY() && scrollbarVisible() {
        trackX := evt.Mouse.X - scrollTrackStart()
        trackW := scrollTrackW()
        if trackX >= 0 && trackX < trackW {
            target := viewOffsetForTrackX(trackX)
            scrollHeld = true
            startScrollAnimation(target)
            stopPropagation()
            return
        }
    }
    if scrollAnimating {
        cancelAnimation()
    }
    if evt.Kind == input.EventMouse && evt.Mouse.Action == input.MousePress && evt.Mouse.Button == input.ButtonLeft {
        relX := evt.Mouse.X - selfX - 2
        newCursor := viewOffset + relX
        if newCursor < 0 {
            newCursor = 0
        }
        if newCursor > len(value) {
            newCursor = len(value)
        }
        cursor = newCursor
        adjustView()
        stopPropagation()
        return
    }
    if evt.Kind == input.EventMouse && evt.Mouse.Action == input.MouseScroll {
        if evt.Mouse.Button == input.ScrollUp && viewOffset > 0 {
            viewOffset = viewOffset - 3
            if viewOffset < 0 {
                viewOffset = 0
            }
            clampCursorToView()
            stopPropagation()
            return
        }
        if evt.Mouse.Button == input.ScrollDown && viewOffset < len(value) - contentW {
            viewOffset = viewOffset + 3
            if viewOffset > len(value) - contentW {
                viewOffset = len(value) - contentW
            }
            clampCursorToView()
            stopPropagation()
            return
        }
    }
    if evt.Special == input.KeyBackspace && evt.Ctrl && cursor > 0 {
        pos := wordLeft()
        value = value[:pos] + value[cursor:]
        cursor = pos
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyBackspace && cursor > 0 {
        value = value[:cursor-1] + value[cursor:]
        cursor = cursor - 1
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyDelete && evt.Ctrl && cursor < len(value) {
        pos := wordRight()
        value = value[:cursor] + value[pos:]
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyDelete && cursor < len(value) {
        value = value[:cursor] + value[cursor+1:]
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyLeft && evt.Ctrl && cursor > 0 {
        cursor = wordLeft()
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyLeft && cursor > 0 {
        cursor = cursor - 1
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyRight && evt.Ctrl && cursor < len(value) {
        cursor = wordRight()
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyRight && cursor < len(value) {
        cursor = cursor + 1
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyHome && cursor > 0 {
        cursor = 0
        adjustView()
        stopPropagation()
        return
    }
    if evt.Special == input.KeyEnd && cursor < len(value) {
        cursor = len(value)
        adjustView()
        stopPropagation()
        return
    }
    if evt.Kind == input.EventKey && evt.Ctrl && evt.Rune == 'w' && cursor > 0 {
        pos := wordLeft()
        value = value[:pos] + value[cursor:]
        cursor = pos
        adjustView()
        stopPropagation()
        return
    }
    if evt.Kind == input.EventKey && !evt.Ctrl && evt.Rune >= 32 {
        value = value[:cursor] + string(evt.Rune) + value[cursor:]
        cursor = cursor + 1
        adjustView()
        stopPropagation()
        return
    }
}
</script>

<style>
.indicator {
    dim: true;
}
.arrow {
    dim: true;
}
.scrollbar {
    dim: true;
}
</style>

<box focusable="true" onkey="handleEvent" cursor-x={cursor - viewOffset + 2} cursor-y="0">
    <box direction="row">
        <text>[</text>
        <text class="indicator">{leftIndicator()}</text>
        <text>{visibleContent()}</text>
        <text class="indicator">{rightIndicator()}</text>
        <text>]</text>
    </box>
    <box direction="row">
        <text class="scrollbar">{scrollSpacer()}</text>
        <text class="arrow">{scrollLeftArrow()}</text>
        <text class="scrollbar">{scrollTrack()}</text>
        <text class="arrow">{scrollRightArrow()}</text>
        <text class="scrollbar">{scrollSpacer()}</text>
    </box>
</box>

<style>
.container {
    border: single;
    padding: 1 2;
}
.title {
    color: green;
    bold: true;
}
.hint {
    color: cyan;
    dim: true;
}
.selected {
    color: yellow;
    bold: true;
}
</style>

<script>
items := sumi.New([]string{"Buy groceries", "Write tests", "Review PR"})
selected := sumi.New(0)

func handleKey(evt sumi.Event) {
    if evt.Kind == sumi.EventSignal { sumi.Quit(); return }
    if evt.Rune == 'q' || (evt.Ctrl && evt.Rune == 'c') { sumi.Quit(); return }
    if evt.Kind == sumi.EventKey {
        n := len(items.Get())
        if n > 0 {
            selected.Set((selected.Get() + 1) % n)
        }
    }
}
</script>

<box class="container" onkey="handleKey">
    <text class="title">Todo List</text>
    <text class="hint">Press any key to cycle, q to quit</text>
    {for i, item := range items.Get() key=item}
        {if i == selected.Get()}
            <text class="selected">> {item}</text>
        {else}
            <text>  {item}</text>
        {/if}
    {/for}
</box>

<script>
var label string = "Count"

count := signal.New(0)

func increment(evt input.Event) {
    if evt.Kind == input.EventKey {
        count.Update(func(n int) int { return n + 1 })
    }
}
</script>

<style>
.label {
    color: cyan;
    bold: true;
}
.count {
    color: yellow;
    bold: true;
}
</style>

<box onkey="increment">
    <text class="label">{label}:</text>
    <text class="count">{count}</text>
</box>

<script>
var label string = "Count"

count := sumi.New(0)

func handleKey(evt sumi.Event) {
    if evt.Kind == sumi.EventKey {
        count.Update(func(n int) int { return n + 1 })
    }
}
</script>

<style>
.label { color: cyan; font-weight: bold; }
.count { color: yellow; font-weight: bold; }
</style>

<div onkey="handleKey">
    <span class="label">{label}:</span>
    <span class="count">{count}</span>
</div>

<script>
func handleKey(evt sumi.Event) {
    if evt.Kind == sumi.EventSignal { sumi.Quit(); return }
    if evt.Ctrl && evt.Rune == 'c' { sumi.Quit(); return }
}
</script>

<style>
.root { flex-direction: row; border-collapse: collapse; }
.panel { flex-grow: 1; border: single; padding: 0 1; }
</style>

<box class="root" onkey="handleKey">
    <box class="panel" border-title="Actual" height="5"></box>
    <box class="panel" border-title="Expected" height="5"></box>
</box>

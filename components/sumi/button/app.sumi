<script>
count := $state(0)

func increment() {
    count = count + 1
}

func handleKey(evt input.Event) {
    if evt.Kind == input.EventSignal {
        app.Quit()
        return
    }
    if evt.Ctrl && evt.Rune == 'c' {
        app.Quit()
        return
    }
}
</script>

<box onkey="handleKey">
    <text>Count: {count}</text>
    <sumi:Button label="Click me" onclick={increment} />
</box>
